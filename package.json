{
  "name": "pranan-companion",
  "version": "0.8.24",
  "private": true,
  "description": "Pranan Companion - AI-powered relationship intelligence for your communication tools",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "build:prod": "vite build --mode production",
    "typecheck": "tsc --noEmit",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "release:zip": "npm run build && cd dist && zip -r ../pranan-companion-v$(node -p \"require(\"../package.json\").version\").zip .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:staging": "VITE_API_HOST=\"${VITE_API_HOST:?Set VITE_API_HOST=https://...your-staging-or-preview-url}\" npm run build && node scripts/build-manifest.mjs",
    "build:preview": "npm run build:staging",
    "prepublish:check": "npm run typecheck && npm test && npm run build",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@sentry/browser": "^10.51.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.27",
    "happy-dom": "^20.8.9",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.5",
    "@playwright/test": "^1.49.1"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
