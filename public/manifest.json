{
  "manifest_version": 3,
  "name": "Pranan: AI Email Assistant in Your Voice",
  "version": "0.8.16",
  "description": "Your AI email twin. One-tap replies in your voice in Gmail, with relationship context, tone control, and smart nudges.",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel",
    "tabs",
    "alarms",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://app.slack.com/*",
    "https://www.linkedin.com/*",
    "https://app.pranan.ai/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Pranan for Chrome",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content/gmail.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://app.slack.com/*"
      ],
      "js": [
        "content/slack.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "content/linkedin.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://app.pranan.ai/*"
      ],
      "js": [
        "content/pranan-app.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "toggle-pranan": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Toggle Pranan side panel"
    }
  },
  "externally_connectable": {
    "matches": [
      "https://app.pranan.ai/*"
    ]
  },
  "short_name": "Pranan"
}
